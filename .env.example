# Example environment variables for AlgoArena backend

# --- SendGrid (recommended) ----------------------------------------------
# Use SendGrid API for reliable delivery. Create an API key in SendGrid and
# set it here. When present, the app will use the SendGrid API instead of SMTP.
SENDGRID_API_KEY=your_sendgrid_api_key_here
SMTP_FROM="AlgoArena" <noreply@yourdomain.com>

# --- SMTP (Gmail example) ------------------------------------------------
# For Gmail, create an App Password (recommended) and use it as SMTP_PASS.
# Note: regular Gmail passwords may not work due to Google security policies.
# If you have 2-Step Verification enabled for your Google account, create an
# App Password here: https://myaccount.google.com/apppasswords

# SMTP host/port/security
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# SMTP credentials
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM="AlgoArena" <noreply@yourdomain.com>

# Optional: override Mail settings
# SMTP_FROM can be any verified sender your SMTP provider accepts.
